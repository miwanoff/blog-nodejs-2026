<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
  <title>Post Created - My blog</title>
</head>
<body>
  <div class="container mt-4">
	<%- include("partials/navbar.ejs") %>  
	<div class="alert alert-success mb-4" role="alert">
  	<h4 class="alert-heading">Success! Your post has been created.</h4>
	</div>
	<div class="card shadow-sm">
  	<div class="card-body">
    	<h1 class="card-title h2"><%- formData.title %></h1>
    	<h6 class="card-subtitle mb-3 text-muted">Category: <span class="badge bg-secondary"><%- formData.category %></span></h6>
    	<p class="card-text" style="white-space: pre-line;"><%- formData.body %></p>
  	</div>
	</div>  
	<a href="/new-post" class="btn btn-outline-primary mt-3">Add another post</a>
  </div>
  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
